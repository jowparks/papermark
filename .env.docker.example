# =============================================================================
# Papermark self-host — copy to `.env` and fill the ✎ values.
#   cp .env.docker.example .env
# See DOCKER.md for the full runbook (which external account each value comes
# from, and which vars must ALSO be set in the Trigger.dev dashboard).
#
# ✎ = you must set this.   Lines without ✎ have working defaults.
# =============================================================================

# ----- Core -----------------------------------------------------------------
NODE_ENV=production
NEXTAUTH_URL=https://docs.example.com                 # ✎ public HTTPS URL of the app
NEXT_PUBLIC_BASE_URL=https://docs.example.com         # ✎ build-time; same as NEXTAUTH_URL
NEXT_PUBLIC_MARKETING_URL=https://docs.example.com    # ✎ build-time
NEXT_PUBLIC_APP_BASE_HOST=docs.example.com            # ✎ build-time; HOST ONLY (no scheme)

# Generate each with: openssl rand -hex 32
# These two MUST also be pasted into the Trigger.dev dashboard env (see DOCKER.md §8.2)
# so the cloud worker's callbacks to /api/mupdf + presign authenticate.
INTERNAL_API_KEY=                                     # ✎ openssl rand -hex 32 (ALSO in Trigger dashboard)
REVALIDATE_TOKEN=                                     # ✎ openssl rand -hex 32 (ALSO in Trigger dashboard)

# Auto-generated by the `secrets-init` service into the `secrets` volume on
# first boot; leave blank here. (NEXTAUTH_SECRET, NEXT_PRIVATE_DOCUMENT_PASSWORD_KEY,
# NEXT_PRIVATE_VERIFICATION_SECRET.)
NEXTAUTH_SECRET=
NEXT_PRIVATE_DOCUMENT_PASSWORD_KEY=
NEXT_PRIVATE_VERIFICATION_SECRET=

# ----- Public access (Cloudflare Tunnel) ------------------------------------
# Connector token for the bundled `cloudflared` service, which publishes the app
# at your public hostname with no exposed host port. Get it for your named tunnel:
#   cloudflared tunnel token <your-tunnel>
# Then, in the Cloudflare Zero Trust dashboard, point the public hostname at
# http://app:3000 (token-based connectors read ingress from the edge, not a local
# config file). See DOCKER.md §10. If you use your own reverse proxy instead,
# remove the `cloudflared` service from docker-compose.yml and leave this blank.
TUNNEL_TOKEN=                                         # ✎ if using the bundled cloudflared service

# ----- Database (managed Neon Postgres) -------------------------------------
POSTGRES_PRISMA_URL=                                  # ✎ Neon POOLED url, ?sslmode=require
POSTGRES_PRISMA_URL_NON_POOLING=                      # ✎ Neon DIRECT url, ?sslmode=require

# ----- Storage (Cloudflare R2, S3-compatible) -------------------------------
NEXT_PUBLIC_UPLOAD_TRANSPORT=s3                       # build-time; keep `s3`
NEXT_PRIVATE_UPLOAD_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com  # ✎
NEXT_PRIVATE_UPLOAD_REGION=auto                       # MUST be `auto` for R2
NEXT_PRIVATE_UPLOAD_BUCKET=papermark                  # ✎ main bucket (private)
NEXT_PRIVATE_ARCHIVE_BUCKET=papermark-archive         # ✎ REQUIRED second bucket (private)
NEXT_PRIVATE_UPLOAD_ACCESS_KEY_ID=                    # ✎ R2 access key id
NEXT_PRIVATE_UPLOAD_SECRET_ACCESS_KEY=                # ✎ R2 secret access key
# Leave NEXT_PRIVATE_UPLOAD_DISTRIBUTION_HOST UNSET -> presigned GET path, private bucket.

# ----- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=                                       # ✎ Resend API key
RESEND_FROM_EMAIL=Papermark <login@example.com>       # ✎ must be a Resend-verified domain

# ----- Background jobs (Trigger.dev Cloud) ----------------------------------
TRIGGER_SECRET_KEY=                                   # ✎ tr_... runtime secret key
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_REF=                                  # ✎ proj_...
TRIGGER_ACCESS_TOKEN=                                 # ✎ tr_pat_... (deploy-time, provision-trigger)

# ----- Analytics (Tinybird) -------------------------------------------------
TINYBIRD_TOKEN=                                       # ✎ workspace admin token
TINYBIRD_HOST=                                        # optional; set for EU/regional (e.g. https://api.tinybird.co)

# ----- Queues (Upstash QStash) ----------------------------------------------
QSTASH_TOKEN=                                         # ✎
QSTASH_CURRENT_SIGNING_KEY=                           # ✎
QSTASH_NEXT_SIGNING_KEY=                              # ✎

# ----- Redis (Upstash REST) -------------------------------------------------
UPSTASH_REDIS_REST_URL=                               # ✎
UPSTASH_REDIS_REST_TOKEN=                             # ✎
UPSTASH_REDIS_REST_LOCKER_URL=                        # ✎ may reuse the same DB as above
UPSTASH_REDIS_REST_LOCKER_TOKEN=                      # ✎ may reuse the same token as above

# =============================================================================
# Leave UNSET (unused in this self-host profile — do not add them):
#   EDGE_CONFIG, GOOGLE_*, LINKEDIN_*, JITSU_*,
#   NEXT_PUBLIC_POSTHOG_KEY, UNSEND_*, NEXT_PRIVATE_CONVERT* / CONVERSION*,
#   VERCEL*, NEXT_PRIVATE_UPLOAD_DISTRIBUTION_HOST
# =============================================================================

# =============================================================================
# Out-of-scope feature placeholders — KEEP these dummy values (do NOT blank them)
# These features are unused in this self-host profile, but their modules run an
# import-time guard that THROWS on an empty value. lib/auth/auth-options.ts
# imports Hanko, so a blank HANKO_* breaks ALL login. Only replace a value if you
# actually intend to enable that feature.
# =============================================================================
HANKO_API_KEY=unused-self-host-placeholder
NEXT_PUBLIC_HANKO_TENANT_ID=00000000-0000-0000-0000-000000000000
OPENAI_API_KEY=sk-unused-self-host-placeholder
STRIPE_SECRET_KEY=sk_test_unused_self_host_placeholder
STRIPE_SECRET_KEY_OLD=sk_test_unused_self_host_placeholder
SLACK_CLIENT_ID=unused-self-host-placeholder
SLACK_CLIENT_SECRET=unused-self-host-placeholder
DUB_API_KEY=dub_unused_self_host_placeholder
